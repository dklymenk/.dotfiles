yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# focus window after active space changes
yabai -m signal --add event=space_changed action="yabai -m window --focus \$(yabai -m query --windows --space | jq .[0].id)"


# yabai -m signal --add event=space_changed action="yabai -m window --focus \$(yabai -m query --windows --space | jq 'map(select(.title != "Microsoft Teams Notification")).[0].id')"
# focus window after active display changes
# yabai -m signal --add event=display_changed action="yabai -m window --focus \$(yabai -m query --windows --space | jq 'map(select(.title != "Microsoft Teams Notification")).[0].id')"

yabai -m signal --add event=display_changed action="yabai -m window --focus \$(yabai -m query --windows --space | jq .[0].id)"

yabai -m config layout bsp

yabai -m config top_padding    0
yabai -m config bottom_padding 0
yabai -m config left_padding   0
yabai -m config right_padding  0

yabai -m config window_gap     8

yabai -m config focus_follows_mouse autoraise

borders style=square active_color=0x9c55bdf9 inactive_color=0xff494d64 width=4.0 &

